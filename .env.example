# ---------------------------------------------------------------------------
# Supabase
#   - browser needs the NEXT_PUBLIC_* pair (anon key, RLS-restricted)
#   - server / sync agent uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY
#   - SUPABASE_URL and NEXT_PUBLIC_SUPABASE_URL hold the same value (project URL)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
# Get it from Supabase → Project Settings → API → service_role key.
# Never commit; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# ---------------------------------------------------------------------------
# SQL Server (ERP — ECO_2020) — only needed by the sync agent (on-prem).
# Same env-var names as the existing PRUEBA-CRM-GEMINI-CODE project.
# ---------------------------------------------------------------------------
MSSQL_SERVER="SRVAPP"
MSSQL_DATABASE="ECO_2020"
MSSQL_USER="erp_reader"
MSSQL_PASSWORD=""
MSSQL_PORT="1433"
MSSQL_ENCRYPT="false"
MSSQL_TRUST_SERVER_CERTIFICATE="true"

# ---------------------------------------------------------------------------
# SMTP — notificaciones de solicitudes de vacaciones a supervisores/admin.
# Puerto 465 = TLS implícito (recomendado). 587 = STARTTLS.
# ---------------------------------------------------------------------------
SMTP_HOST="mail.ejemplo.com"
SMTP_PORT="465"
SMTP_USER="notificaciones@ejemplo.com"
SMTP_PASS=""
SMTP_FROM="Vacaciones Ecosistemas <notificaciones@ejemplo.com>"

# URL pública del app (para enlaces en correos). Sin slash final.
# En Vercel se puede usar https://control-de-vacaciones.vercel.app o tu dominio.
NEXT_PUBLIC_APP_URL="https://control-de-vacaciones.vercel.app"
